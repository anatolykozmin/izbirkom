# Скопируйте этот файл в .env и подставьте свои значения (файл .env в git не коммитить).
# SECRET_KEY: для локалки — длинная случайная строка; в проде — уникальный секрет.
SECRET_KEY=change-me-for-local-testing-only

# true — заглушка: SMTP не вызывается, код печатается в терминале (uvicorn).
# false — реальная отправка через Gmail.
EMAIL_DEBUG=false

COOKIE_SECURE=false

# Gmail: пароль приложения (16 символов), не обычный пароль аккаунта.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=
SMTP_FROM=your@gmail.com
SMTP_USE_TLS=true
